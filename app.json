{
  "expo": {
    "name": "LocalConvert",
    "slug": "localconvert",
    "scheme": "localconvert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1838"
    },
    "ios": {
      "bundleIdentifier": "dev.pagl.localconvert",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "LocalConvert braucht Zugriff auf deine Fotos und Videos, um sie umzuwandeln. Nichts verlässt dein Gerät.",
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "All files",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "public.data",
              "public.content"
            ]
          }
        ]
      },
      "buildNumber": "1"
    },
    "android": {
      "package": "dev.pagl.localconvert",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1838"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "SEND",
          "category": [
            "DEFAULT"
          ],
          "data": [
            {
              "mimeType": "*/*"
            }
          ]
        },
        {
          "action": "SEND_MULTIPLE",
          "category": [
            "DEFAULT"
          ],
          "data": [
            {
              "mimeType": "*/*"
            }
          ]
        }
      ],
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "pagl400",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "LocalConvert braucht Zugriff auf deine Fotos und Videos, um sie umzuwandeln. Nichts verlässt dein Gerät.",
          "savePhotosPermission": "LocalConvert speichert das Konvertierungs-Ergebnis nur, wenn du es ausdrücklich exportierst.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "414fbe0d-fee3-4020-acf6-feb1de679530"
      }
    }
  }
}
