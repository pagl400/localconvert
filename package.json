{
  "name": "localconvert",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "web": "expo start --web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test:converters": "node tests/run-converters.mjs",
    "test:unit": "node tests/run-unit.mjs",
    "test:audit": "node tests/scripts/audit-gui-coverage.mjs",
    "test:swift": "swift test --package-path modules/expo-media-convert",
    "test:all": "pnpm test:unit && pnpm test:audit && pnpm test:converters && pnpm test:swift",
    "test:pdf": "swift tests/scripts/test-pdf.swift test-fixtures/pdf-image-only.pdf test-fixtures/pdf-text-multipage.pdf",
    "test:build-fixtures": "node tests/scripts/build-fixtures.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.5.0",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.0",
    "@types/turndown": "^5.0.6",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-print": "^55.0.15",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "fast-xml-parser": "^5.8.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.3",
    "pdf-lib": "^1.17.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "turndown": "^7.2.4",
    "xlsx": "^0.18.5",
    "yaml": "^2.9.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^18.13.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^10.0.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "searchPaths": [
        "modules"
      ]
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "unrs-resolver"
    ],
    "overrides": {
      "postcss": "^8.5.10"
    }
  }
}
